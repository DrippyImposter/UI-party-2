-- Utility Functions
local function createHoverEffect(button, getOriginalColor)
    -- If getOriginalColor is a function, call it; otherwise use it as a static color
    local isFunction = type(getOriginalColor) == "function"
    
    button.MouseEnter:Connect(function()
        local originalColor = isFunction and getOriginalColor() or getOriginalColor
        local hoverColor = originalColor:Lerp(Color3.fromRGB(255, 255, 255), 0.06)
        button.BackgroundColor3 = hoverColor
    end)
    
    button.MouseLeave:Connect(function()
        local originalColor = isFunction and getOriginalColor() or getOriginalColor
        button.BackgroundColor3 = originalColor
    end)
end

local function updateCheckboxAppearance(checkbox, isEnabled, theme)
    if isEnabled then
        checkbox.Text = "✓"
        checkbox.TextColor3 = theme.background  -- Dark checkmark
        checkbox.TextScaled = true
        checkbox.BackgroundColor3 = theme.dropdown  -- Grey background
        checkbox.BorderColor3 = theme.accent
    else
        checkbox.Text = ""
        checkbox.TextColor3 = theme.toggleOn
        checkbox.BackgroundColor3 = theme.dropdown
        checkbox.BorderColor3 = theme.accent
    end
end

-- Main Window Creation
function UILibrary.new(config)
    local self = setmetatable({}, UILibrary)
    
    config = config or {}
    self.title = config.title or "UI Library"
    self.theme = config.theme or defaultTheme
    self.position = config.position or UDim2.new(0.5, -200, 0.5, -310)
    self.toggleKey = config.toggleKey or Enum.KeyCode.H
    self.configFolder = config.configFolder or "UILibrary_Configs"
    self.configGet = config.configGet
    self.configSet = config.configSet
    
    -- Hardcoded window size: 400x620 for PC/tablet, 320x480 for phone
    self.size = UDim2.new(0, 400, 0, 620)
    
    -- Check if phone (small screen + touch), not tablet
    local screenSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
    local isSmallScreen = screenSize.X <= 600 or screenSize.Y <= 400
    self.isPhone = UserInputService.TouchEnabled and isSmallScreen
    
    if self.isPhone then
        self.size = UDim2.new(0, 320, 0, 480)
        self.position = UDim2.new(0.5, -160, 0.5, -240)
    end
    
    self.tabs = {}
    self.currentTab = nil
    
    self:_createBase()
    self:_setupDragging()
    self:_setupToggle()
    
    return self
end

function UILibrary:SaveConfig(name)
    local writefileFn = _getFs()
    local wf, _, _, _, _, _, _ = _getFs()
    if not wf then return false end

    local folder = _getConfigDir(self)
    _ensureFolder(folder)

    local payload = nil
    if type(self.configGet) == "function" then
        local ok, res = pcall(self.configGet)
        if ok then payload = res end
    end
    if type(payload) ~= "table" then payload = {} end

    local ok, data = pcall(function() return HttpService:JSONEncode(payload) end)
    if not ok then return false end

    local path = _getConfigPath(self, name)
    local ok2 = pcall(function() wf(path, data) end)
    return ok2
end

function UILibrary:LoadConfig(name)
    local _, rf = _getFs()
    local _, rf2, _, isf = _getFs()
    local rfFn, isfileFn = rf2, isf
    if not rfFn then return false end

    local path = _getConfigPath(self, name)
    if isfileFn and (not isfileFn(path)) then return false end

    local ok, raw = pcall(function() return rfFn(path) end)
    if not ok or not raw then return false end

    local ok2, decoded = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or type(decoded) ~= "table" then return false end

    if type(self.configSet) == "function" then
        pcall(self.configSet, decoded)
        return true
    end
    return false
end

function UILibrary:DeleteConfig(name)
    local _, _, df, isf = _getFs()
    if not df then return false end

    local path = _getConfigPath(self, name)
    if isf and (not isf(path)) then return false end

    local ok = pcall(function() df(path) end)
    return ok
end

function UILibrary:GetConfigs()
    local _, _, _, _, lf = _getFs()
    if not lf then return {} end

    local folder = _getConfigDir(self)
    _ensureFolder(folder)

    local ok, files = pcall(function() return lf(folder) end)
    if not ok or type(files) ~= "table" then return {} end

    local configs = {}
    for _, p in ipairs(files) do
        local base = _basename(p)
        local name = base:gsub("%.json$", "")
        if name ~= "" then table.insert(configs, name) end
    end
    table.sort(configs)
    return configs
end

