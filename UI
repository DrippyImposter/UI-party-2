-- Intro Animation (5 seconds with oscillating logo)
function UILibrary:_createIntro()
    -- Intro frame (same size and position as main GUI)
    local introFrame = Instance.new("Frame")
    introFrame.Size = self.size
    introFrame.Position = self.position
    introFrame.BackgroundColor3 = self.theme.background
    introFrame.BorderSizePixel = 0
    introFrame.ClipsDescendants = true
    introFrame.ZIndex = 1000
    introFrame.Parent = self.screenGui
    
    -- Glow effect for intro
    local introGlow = Instance.new("Frame")
    introGlow.Size = UDim2.new(1, 10, 1, 10)
    introGlow.Position = UDim2.new(0, -5, 0, -5)
    introGlow.BackgroundColor3 = self.theme.glow
    introGlow.BackgroundTransparency = 0.8
    introGlow.BorderSizePixel = 0
    introGlow.ZIndex = 999
    introGlow.Parent = introFrame
    
    local glowCorner = Instance.new("UICorner")
    glowCorner.CornerRadius = UDim.new(0, 6)
    glowCorner.Parent = introGlow
    
    -- Inner border for intro
    local introInner = Instance.new("Frame")
    introInner.Size = UDim2.new(1, -4, 1, -4)
    introInner.Position = UDim2.new(0, 2, 0, 2)
    introInner.BackgroundColor3 = self.theme.surface
    introInner.BorderSizePixel = 0
    introInner.ZIndex = 1001
    introInner.Parent = introFrame
    
    local innerCorner = Instance.new("UICorner")
    innerCorner.CornerRadius = UDim.new(0, 4)
    innerCorner.Parent = introInner
    
    -- Draggable area for intro (invisible button covering the whole intro)
    local introDragArea = Instance.new("TextButton")
    introDragArea.Size = UDim2.new(1, 0, 1, 0)
    introDragArea.Position = UDim2.new(0, 0, 0, 0)
    introDragArea.BackgroundTransparency = 1
    introDragArea.Text = ""
    introDragArea.ZIndex = 1003
    introDragArea.Active = true
    introDragArea.Parent = introInner
    
    -- Logo image (centered, oscillating)
    local logo = Instance.new("ImageLabel")
    logo.Size = UDim2.new(0, 120, 0, 120)
    logo.Position = UDim2.new(0.5, -60, 0.5, -60)
    logo.BackgroundTransparency = 1
    logo.Image = "rbxassetid://107520574095750"
    logo.ZIndex = 1002
    logo.Parent = introInner
    
    -- Setup dragging for intro
    local dragging = false
    local dragInput = nil
    local dragStart = nil
    local startPos = nil
    
    local function updateIntro(input)
        local delta = input.Position - dragStart
        introFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
    
    introDragArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = introFrame.Position
            dragInput = input
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    dragInput = nil
                end
            end)
        end
    end)
    
    introDragArea.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input == dragInput then
            updateIntro(input)
            return
        end
        if input.UserInputType == Enum.UserInputType.Touch then
            updateIntro(input)
        end
    end)
    
    -- Oscillating animation (smooth sine wave)
    local oscillating = true
    task.spawn(function()
        local time = 0
        while oscillating do
            time = time + 0.05
            -- Smooth sine wave: oscillate between 0.85 and 1.15 scale
            local scale = 1 + math.sin(time * 3) * 0.15
            logo.Size = UDim2.new(0, 120 * scale, 0, 120 * scale)
            logo.Position = UDim2.new(0.5, -60 * scale, 0.5, -60 * scale)
            task.wait(0.05)
        end
    end)
    
    -- After 5 seconds: fade out intro, show main GUI
    task.spawn(function()
        task.wait(5)
        oscillating = false
        
        -- Sync main GUI position to intro position
        self.frame.Position = introFrame.Position
        
        -- Fade out intro
        local fadeInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local fadeTweens = {
            TweenService:Create(introFrame, fadeInfo, {BackgroundTransparency = 1}),
            TweenService:Create(introInner, fadeInfo, {BackgroundTransparency = 1}),
            TweenService:Create(logo, fadeInfo, {ImageTransparency = 1}),
            TweenService:Create(introGlow, fadeInfo, {BackgroundTransparency = 1})
        }
        
        -- Play fade out tweens
        for _, tween in ipairs(fadeTweens) do tween:Play() end
        
        -- Show main GUI immediately (no fade needed since intro covers it)
        self.frame.Visible = true
        
        -- Wait for fade to complete, then destroy intro
        fadeTweens[1].Completed:Wait()
        introFrame:Destroy()
        
        -- Mark intro as complete so toggle key works
        self.introComplete = true
    end)
end

function UILibrary:_setupDragging()
    local dragging = false
    local dragInput = nil
    local dragStart = nil
    local startPos = nil
    
    -- Smooth dragging variables
    local targetPos = nil
    local currentPos = self.frame.Position
    local smoothness = 0.15 -- Lower = smoother/slower, Higher = snappier/faster
    
    local RunService = game:GetService("RunService")
    local smoothConnection = nil
    
    local function startSmoothDrag()
        if smoothConnection then return end
        smoothConnection = RunService.Heartbeat:Connect(function()
            if not targetPos then return end
            -- Lerp current position toward target
            local lerp = function(a, b, t)
                return a + (b - a) * t
            end
            local newX = lerp(currentPos.X.Offset, targetPos.X.Offset, smoothness)
            local newY = lerp(currentPos.Y.Offset, targetPos.Y.Offset, smoothness)
            currentPos = UDim2.new(startPos.X.Scale, newX, startPos.Y.Scale, newY)
            self.frame.Position = currentPos
        end)
    end
    
    local function stopSmoothDrag()
        if smoothConnection then
            smoothConnection:Disconnect()
            smoothConnection = nil
        end
    end
    
    local function updateTarget(input)
        local delta = input.Position - dragStart
        targetPos = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
    
    self.titleBar.Active = true
    
    self.titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = self.frame.Position
            currentPos = startPos
            targetPos = startPos
            dragInput = input
            
            startSmoothDrag()
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    dragInput = nil
                    stopSmoothDrag()
                end
            end)
        end
    end)
    
    self.titleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input == dragInput then
            updateTarget(input)
            return
        end
        if input.UserInputType == Enum.UserInputType.Touch then
            updateTarget(input)
        end
    end)
end

function UILibrary:_setupToggle()
    UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
        if gameProcessedEvent then return end
        if UserInputService:GetFocusedTextBox() then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and 
           input.KeyCode == self.toggleKey then
            -- Don't toggle if intro is still playing
            if not self.introComplete then return end
            
            self.frame.Visible = not self.frame.Visible
            
            -- Reset all toggle hover states when toggling UI visibility
            for _, tab in ipairs(self.tabs) do
                for _, elem in ipairs(tab.elements) do
                    if elem.type == "toggle" and elem.checkbox then
                        -- Reset hover state tracking
                        elem.isMouseOver = false
                        elem.justToggled = false
                        -- Ensure checkbox is fully visible
                        elem.checkbox.BackgroundTransparency = 0
                        elem.checkbox.BorderSizePixel = 1
                        -- Get current state from text
                        local isEnabled = elem.checkbox.Text == "✓"
                        -- Force correct colors based on state
                        if isEnabled then
                            elem.checkbox.BackgroundColor3 = self.theme.dropdown
                            elem.checkbox.TextColor3 = self.theme.background
                            elem.checkbox.Text = "✓"
                        else
                            elem.checkbox.BackgroundColor3 = self.theme.dropdown
                            elem.checkbox.TextColor3 = self.theme.toggleOn
                            elem.checkbox.Text = ""
                        end
                        elem.checkbox.BorderColor3 = self.theme.accent
                    end
                end
            end
            
        end
    end)
end

function UILibrary:_moveIndicatorTo(button, instant)
    local firstTabPos = self.tabs[1] and self.tabs[1].button.Position.X.Offset or 0
    local targetX = button.Position.X.Offset - firstTabPos
    local targetW = button.Size.X.Offset - 12
    
    -- Center the indicator under the tab:
    -- Tab width = 95, Indicator width = 83, Need 6px margin on each side
    -- So indicator X should be tab.X + 6 (not just tab.X)
    local centeredX = targetX + 6 + 6  -- +6 for relative offset, +6 for centering margin
    
    local targetPos = UDim2.new(0, centeredX, 1, -3)
    local targetSize = UDim2.new(0, targetW, 0, 3)
    
    if instant then
        self.activeIndicator.Position = targetPos
        self.activeIndicator.Size = targetSize
        return
    end
    
    local info = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local t1 = TweenService:Create(self.activeIndicator, info, {Position = targetPos})
    local t2 = TweenService:Create(self.activeIndicator, info, {Size = targetSize})
    t1:Play()
    t2:Play()
end

-- Tab Creation
function UILibrary:addTab(name)
    local tab = {}
    tab.name = name
    tab.elements = {}
    
    -- Create tab button
    local tabIndex = #self.tabs + 1
    local xPos = 6 + (tabIndex - 1) * 101
    
    tab.button = Instance.new("TextButton")
    tab.button.Size = UDim2.new(0, 95, 1, -6)
    tab.button.Position = UDim2.new(0, xPos, 0, 3)
    tab.button.BackgroundColor3 = self.theme.dropdown
    tab.button.BorderSizePixel = 0
    tab.button.Text = name
    tab.button.TextColor3 = self.theme.text
    tab.button.Font = Enum.Font.Code
    tab.button.TextSize = 12
    tab.button.Parent = self.tabsRow
    
    local tabCorner = Instance.new("UICorner")
    tabCorner.CornerRadius = UDim.new(0, 6)
    tabCorner.Parent = tab.button
    
    -- Create content frame
    tab.content = Instance.new("ScrollingFrame")
    tab.content.Size = UDim2.new(1, -20, 1, -60)
    tab.content.Position = UDim2.new(0, 10, 0, 70)
    tab.content.BackgroundTransparency = 1
    tab.content.ScrollBarThickness = 0
    tab.content.Parent = self.innerBorder
    tab.content.Visible = false
    
    -- Layout
    tab.layout = Instance.new("UIListLayout")
    tab.layout.SortOrder = Enum.SortOrder.LayoutOrder
    tab.layout.Padding = UDim.new(0, 6)
    tab.layout.Parent = tab.content
    
    -- Store base canvas size for this tab
    tab.baseCanvasHeight = 10
    
    -- Auto-resize canvas
    tab.content.CanvasSize = UDim2.new(0, 0, 0, 10)
    tab.layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = tab.layout.AbsoluteContentSize.Y + 18
        tab.baseCanvasHeight = math.max(h, 200)
        tab.content.CanvasSize = UDim2.new(0, 0, 0, tab.baseCanvasHeight)
    end)
    
    -- Button click handler
    tab.button.MouseButton1Click:Connect(function()
        self:_selectTab(tab)
    end)
    
    -- Update canvas size for tabs
    self.tabsRow.CanvasSize = UDim2.new(0, xPos + 100, 0, 30)
    
    table.insert(self.tabs, tab)
    
    -- Select first tab
    if #self.tabs == 1 then
        self:_selectTab(tab)
    end
    
    return setmetatable(tab, {__index = self})
end

function UILibrary:_selectTab(tab)
    -- Hide all tabs
    for _, t in ipairs(self.tabs) do
        t.content.Visible = false
        t.button.BackgroundColor3 = self.theme.dropdown
        t.button.TextColor3 = self.theme.text
    end
    
    -- Show selected tab
    tab.content.Visible = true
    tab.button.BackgroundColor3 = self.theme.surface
    tab.button.TextColor3 = self.theme.accent2
    
    self.currentTab = tab
    self:_moveIndicatorTo(tab.button)
end

