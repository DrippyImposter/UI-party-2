--[[
    Modern UI Library - ENHANCED VERSION
    A comprehensive UI library for Roblox with support for:
    - Tabs
    - Buttons (normal, toggleable, one-time action) with setText
    - Info containers
    - Sliders (with decimal support and custom labels)
    - Textboxes
    - Dropdowns (small, positioned properly) with setText
    - And more!
    
    NEW FEATURES:
    - setText() support for: Buttons, Sliders, Action Toggles, Toggles, Type Switchers, Dropdowns
    - Decimal support for sliders (config.decimals)
    - Custom text labels for sliders (config.labels) - optional
]]

local UILibrary = {}
UILibrary.__index = UILibrary

-- Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")

local Player = Players.LocalPlayer

local function _getFs()
    local wf = (writefile or (syn and syn.writefile) or (fluxus and fluxus.writefile) or nil)
    local rf = (readfile or (syn and syn.readfile) or (fluxus and fluxus.readfile) or nil)
    local df = (delfile or (syn and syn.delfile) or (fluxus and fluxus.delfile) or nil)
    local isf = (isfile or (syn and syn.isfile) or (fluxus and fluxus.isfile) or nil)
    local lf = (listfiles or (syn and syn.listfiles) or (fluxus and fluxus.listfiles) or nil)
    local mf = (makefolder or (syn and syn.makefolder) or (fluxus and fluxus.makefolder) or nil)
    local isfld = (isfolder or (syn and syn.isfolder) or (fluxus and fluxus.isfolder) or nil)
    return wf, rf, df, isf, lf, mf, isfld
end

local function _ensureFolder(path)
    local _, _, _, _, _, makefolderFn, isfolderFn = _getFs()
    if not makefolderFn then return false end
    if isfolderFn and isfolderFn(path) then return true end
    local ok = pcall(function() makefolderFn(path) end)
    return ok
end

local function _basename(path)
    return tostring(path):match("[^/\\]+$") or tostring(path)
end

local function _sanitizeName(name)
    name = tostring(name or "")
    name = name:gsub("^%s+", ""):gsub("%s+$", "")
    name = name:gsub("[^%w%-%_ ]", "")
    name = name:gsub("%s+", " ")
    return name
end

local function _getConfigDir(self)
    local folder = (self and self.configFolder) or "UILibrary_Configs"
    folder = _sanitizeName(folder)
    if folder == "" then folder = "UILibrary_Configs" end
    return folder
end

local function _getConfigPath(self, name)
    local folder = _getConfigDir(self)
    local clean = _sanitizeName(name)
    if clean == "" then clean = "default" end
    return folder .. "/" .. clean .. ".json"
end

