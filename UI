-- CreateToggle('Noclip 🚶', false, Color3.fromRGB(0, 125, 255), 0.25, function(Value) ... end)
function UILibrary:CreateToggle(name, default, color, transparency, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 24)
    row.BackgroundTransparency = 1
    row.LayoutOrder = #self.elements + 1
    row.Parent = self.content
    
