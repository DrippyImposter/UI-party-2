function UILibrary:showNotification(text, duration)
    duration = duration or 4
    
    local container = self:createNotificationContainer()
    
    -- Calculate text size dynamically
    local TextService = game:GetService("TextService")
    local maxWidth = 300 -- Account for padding (320 - 20)
    local textSize = TextService:GetTextSize(
        text,
        12,
        Enum.Font.Code,
        Vector2.new(maxWidth, math.huge)
    )
    
    -- Base height: padding (16) + minimum readable area, plus text height
    local baseHeight = 34 -- padding (8 top + 8 bottom) + timer bar (4) + extra spacing (14)
    local contentHeight = textSize.Y + 20 -- text height + extra padding for readability
    local totalHeight = math.max(50, baseHeight + contentHeight)
    
    local notification = Instance.new("Frame")
    notification.Size = UDim2.new(1, 0, 0, totalHeight)
    notification.BackgroundColor3 = self.theme.background
    notification.BorderColor3 = self.theme.accent2
    notification.BorderSizePixel = 2
    notification.Parent = container
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = notification
    
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 10)
    padding.PaddingRight = UDim.new(0, 10)
    padding.PaddingTop = UDim.new(0, 8)
    padding.PaddingBottom = UDim.new(0, 8)
    padding.Parent = notification
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, -12) -- Leave space for timer bar
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = self.theme.text
    label.Font = Enum.Font.Code
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Top
    label.TextWrapped = true
    label.Parent = notification
    
    local timerBar = Instance.new("Frame")
    timerBar.Size = UDim2.new(1, 0, 0, 4)
    timerBar.Position = UDim2.new(0, 0, 1, -4)
    timerBar.BackgroundColor3 = self.theme.accent2
    timerBar.Parent = notification
    
    local timerCorner = Instance.new("UICorner")
    timerCorner.CornerRadius = UDim.new(0, 2)
    timerCorner.Parent = timerBar
    
    task.spawn(function()
        task.wait(0.05)
        local startSize = timerBar.Size
        local targetX = 0
        local steps = duration * 20
        local stepDelay = 0.05
        
        for i = 1, steps do
            if not timerBar or not timerBar.Parent then return end
            local progress = 1 - (i / steps)
            timerBar.Size = UDim2.new(progress, 0, 0, 4)
            task.wait(stepDelay)
        end
        
        if timerBar and timerBar.Parent then
            local fadeInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            TweenService:Create(notification, fadeInfo, {BackgroundTransparency = 1}):Play()
            TweenService:Create(label, fadeInfo, {TextTransparency = 1}):Play()
            TweenService:Create(timerBar, fadeInfo, {BackgroundTransparency = 1}):Play()
            
            task.wait(0.3)
            notification:Destroy()
        end
    end)
    
    return notification
end

