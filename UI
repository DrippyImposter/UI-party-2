    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    contentLayout.Padding = UDim.new(0, 6)
    contentLayout.Parent = content
    
    local expanded = false
    header.MouseButton1Click:Connect(function()
        expanded = not expanded
        content.Visible = expanded
        header.Text = (expanded and "▼ " or "▶ ") .. name
        
        if expanded then
            task.wait()
            content.Size = UDim2.new(1, 0, 0, contentLayout.AbsoluteContentSize.Y)
        else
            content.Size = UDim2.new(1, 0, 0, 0)
        end
    end)
    
    table.insert(self.elements, {type = "section", element = header, content = content})
    
    -- Create simplified methods for the section
    function section:CreateButton(buttonName, buttonCallback)
        local btn = section.parent:addButton({
            text = buttonName,
            callback = buttonCallback
        })
        btn.element.Parent = content
        table.insert(section.elements, btn)
        return btn
    end
    
    function section:CreateToggle(toggleName, toggleDefault, toggleColor, toggleTransparency, toggleCallback)
        local toggle = section.parent:CreateToggle(toggleName, toggleDefault, toggleColor, toggleTransparency, toggleCallback)
        toggle.element.Parent = content
        table.insert(section.elements, toggle)
        return toggle
    end
    
    function section:CreateDropdown(dropdownName, dropdownOptions, dropdownDefault, dropdownTransparency, dropdownCallback)
        local dropdown = section.parent:CreateDropdown(dropdownName, dropdownOptions, dropdownDefault, dropdownTransparency, dropdownCallback)
        dropdown.element.Parent = content
        table.insert(section.elements, dropdown)
        return dropdown
    end
    
    function section:CreateTextbox(textboxName, textboxPlaceholder, textboxCallback)
        local txt = section.parent:CreateTextbox(textboxName, textboxPlaceholder, textboxCallback)
        txt.element.Parent = content
        table.insert(section.elements, txt)
        return txt
    end
    
    function section:CreateLabel(labelName)
        local lbl = section.parent:CreateLabel(labelName)
        lbl.element.Parent = content
        table.insert(section.elements, lbl)
        return lbl
    end
    
    function section:CreateSlider(sliderName, sliderMin, sliderMax, sliderDefault, sliderCallback)
        local sld = section.parent:CreateSlider(sliderName, sliderMin, sliderMax, sliderDefault, sliderCallback)
        sld.element.Parent = content
        table.insert(section.elements, sld)
        return sld
    end
    
    return section
end

